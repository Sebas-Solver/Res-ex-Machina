# ============================================
# Res ex Machina — Environment Variables
# ============================================

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://rexm:rexm_dev_password@localhost:5432/rexm

# --- Redis ---
# Development: Local Redis → redis://localhost:6379
# Alpha:       Upstash     → rediss://default:TOKEN@host.upstash.io:6379 (TLS)
REDIS_URL=redis://localhost:6379

# --- Blockchain L2 ---
# Development: Local Anvil → http://localhost:8545 (chain 31337)
# Alpha:       Base Sepolia → https://sepolia.base.org (chain 84532)
L2_RPC_URL=http://localhost:8545
L2_CHAIN_ID=31337
FEE_RECEIVER_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
FEE_MINIMUM_AMOUNT=0.01
# Maximum age of the fee transaction (in hours, default: 24)
FEE_TX_MAX_AGE_HOURS=24

# --- Anchoring ---
# ⚠️ NEVER commit a real private key
# For local development, use one of the Anvil default accounts.
# See: https://book.getfoundry.sh/reference/anvil/#default-accounts
# ⚠️ NEVER use Anvil keys on real networks (mainnet/testnet with funds)
ANCHOR_WALLET_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# 💡 In production, set FEE_RECEIVER_ADDRESS to the SAME address derived from
#    ANCHOR_WALLET_PRIVATE_KEY. This creates a self-sustaining loop:
#    fees received → same wallet pays gas for anchoring.

# --- Monitoring (optional) ---
# SENTRY_DSN=https://xxx@sentry.io/yyy

# --- Admin Dashboard (optional) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ADMIN_API_KEY=your-secret-key-at-least-32-characters-long

