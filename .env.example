# ============================================
# Res ex Machina — Variables de entorno
# ============================================

# --- Servidor ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Base de datos (PostgreSQL) ---
DATABASE_URL=postgres://rexm:rexm_dev_password@localhost:5432/rexm

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Blockchain L2 ---
# En desarrollo: Anvil (blockchain local en Docker) → localhost:8545
# En producción: Polygon PoS RPC → https://polygon-rpc.com
L2_RPC_URL=http://localhost:8545
L2_CHAIN_ID=31337
FEE_RECEIVER_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
FEE_MINIMUM_AMOUNT=0.01
# Antigüedad máxima de la tx de fee (en horas, default: 24)
FEE_TX_MAX_AGE_HOURS=24

# --- Anchoring ---
# ⚠️ NUNCA commitear la clave privada real
# Esta es la cuenta #0 de Anvil (solo para desarrollo)
ANCHOR_WALLET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
