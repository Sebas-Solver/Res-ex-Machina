{
    "name": "@res-ex-machina/sdk",
    "version": "0.1.0",
    "description": "Official Res ex Machina SDK — neutral registry for AI-generated content provenance",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "viem": "^2.0.0"
    },
    "devDependencies": {
        "typescript": "^5.9.3",
        "viem": "^2.45.2",
        "vitest": "^4.0.18"
    },
    "keywords": [
        "res-ex-machina",
        "rxm",
        "proof-of-generation",
        "ai-agents",
        "ai-provenance",
        "blockchain",
        "eip-712",
        "traceability",
        "ai-registry"
    ],
    "author": "Sebas-Solver <sebas.solver@gmail.com>",
    "homepage": "https://github.com/Sebas-Solver/Res-ex-Machina/tree/main/packages/sdk#readme",
    "license": "ISC",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Sebas-Solver/Res-ex-Machina.git",
        "directory": "packages/sdk"
    },
    "bugs": {
        "url": "https://github.com/Sebas-Solver/Res-ex-Machina/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@x402/core": "^2.11.0",
        "@x402/evm": "^2.11.0"
    }
}
