# ============================================
# Res ex Machina — Production Environment Variables
# ============================================
#
# ⚠️ This file contains the PRODUCTION configuration template.
# NEVER commit actual secrets. Use environment variables or a secrets manager.
#
# Copy this to .env.production and fill in real values.

# --- Server ---
PORT=3000
NODE_ENV=production
LOG_LEVEL=warn

# --- Database (PostgreSQL) ---
# Use a managed PostgreSQL service (Neon, Supabase, RDS, etc.)
DATABASE_URL=postgres://user:PASSWORD@host:5432/rexm?sslmode=require

# --- Redis ---
# Use a managed Redis service with TLS (Upstash, ElastiCache, etc.)
# TLS is MANDATORY in production (rediss:// not redis://)
REDIS_URL=rediss://default:TOKEN@host.upstash.io:6379

# --- Blockchain L2 ---
L2_RPC_URL=https://sepolia.base.org
L2_CHAIN_ID=84532
FEE_RECEIVER_ADDRESS=0x_YOUR_FEE_RECEIVER_ADDRESS
FEE_MINIMUM_AMOUNT=0.01
FEE_TX_MAX_AGE_HOURS=24

# --- Anchoring ---
# ⚠️ NEVER hardcode. Use secrets manager (AWS KMS, GCP KMS, HashiCorp Vault)
# or secure environment variable injection from your deployment platform.
ANCHOR_WALLET_PRIVATE_KEY=0x_INJECTED_FROM_SECRETS_MANAGER

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://your-frontend.com,https://sebas-solver.github.io

# --- Monitoring ---
SENTRY_DSN=https://xxx@sentry.io/yyy

# --- Admin Dashboard ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your-secret-key-at-least-32-characters-long

# ============================================
# P0-1: Rate Limit Degradation Policy
# ============================================
#
# Controls rate limiter behavior when Redis is unavailable.
# In production, writes MUST fail-closed (503) to prevent abuse during outages.
#
# Options for WRITE:
#   '503'            → Write endpoints return 503 Service Unavailable (RECOMMENDED)
#   'local_fallback' → Fallback to strict in-memory limit (5 req/min, per-instance)
#
# Options for READ:
#   'local_fallback' → Conservative in-memory limit (30 req/min, per-instance)
#
# ⚠️ NEVER set RATE_LIMIT_WRITE_ON_REDIS_DOWN=local_fallback in production
#    unless you accept that rate limits won't be shared across instances.
RATE_LIMIT_WRITE_ON_REDIS_DOWN=503
RATE_LIMIT_READ_ON_REDIS_DOWN=local_fallback

# ============================================
# P0-2: MCP Server Security
# ============================================
#
# Allow switching to 'auto' confirmation mode (fully autonomous agent).
# Default: false. ALWAYS. Auto mode is an explicit opt-in, not a default.
# Changing to 'auto' always requires a mandatory reason (audit trail).
#
# ⚠️ In production, leave this as false unless you have a specific, documented
#    use case for autonomous agent operation.
MCP_ALLOW_AUTO_MODE=false

# --- Worker ---
START_INLINE_WORKER=true
