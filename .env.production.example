# ============================================
# Res ex Machina — Production Environment Variables
# ============================================
# Copy this file to .env.production and fill in all values.
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# --- Database ---
DATABASE_URL=postgres://rexm:YOUR_SECURE_PASSWORD@postgres:5432/rexm
POSTGRES_DB=rexm
POSTGRES_USER=rexm
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Blockchain L2 ---
L2_RPC_URL=https://sepolia.base.org
L2_CHAIN_ID=84532
FEE_RECEIVER_ADDRESS=0xYOUR_FEE_RECEIVER_ADDRESS
FEE_MINIMUM_AMOUNT=0.01
FEE_TX_MAX_AGE_HOURS=24
ANCHOR_WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# --- Server ---
PORT=3000

# --- Monitoring (optional) ---
# SENTRY_DSN=https://xxx@sentry.io/yyy

# --- Admin Dashboard (optional, min 32 chars) ---
# ADMIN_API_KEY=your-secret-key-at-least-32-characters-long
