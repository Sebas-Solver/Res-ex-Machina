{
    "info": {
        "name": "Res ex Machina — API Alpha",
        "description": "Complete API collection for Res ex Machina.\nBase URL: https://res-ex-machina-api.onrender.com\n\nFor GET endpoints: they work directly.\nFor POST /records: you need to sign with EIP-712 (use the test-alpha.ts script for the full flow).",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "https://res-ex-machina-api.onrender.com",
            "type": "string"
        },
        {
            "key": "record_id",
            "value": "REPLACE_WITH_A_REAL_RECORD_ID",
            "type": "string"
        },
        {
            "key": "content_hash",
            "value": "sha256:REPLACE_WITH_A_REAL_HASH",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "🏥 Health Check",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/v1/health",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "v1",
                        "health"
                    ]
                },
                "description": "Verifies that the API, database, Redis, and blockchain are operational."
            }
        },
        {
            "name": "📝 Create record (POST /records)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"pog_bundle\": {\n        \"schema\": \"pog.v1\",\n        \"content_hash\": \"sha256:YOUR_SHA256_HASH_HERE\",\n        \"agent_wallet\": \"0xYOUR_WALLET_HERE\",\n        \"model_id\": \"gpt-4o\",\n        \"runtime_id\": \"postman-test\",\n        \"generation_process\": {\n            \"process_type\": \"direct\",\n            \"human_intervention_level\": 0,\n            \"pipeline_steps\": 1\n        },\n        \"timestamp\": \"2026-02-14T12:00:00.000Z\",\n        \"nonce\": \"your_unique_nonce_here\",\n        \"signature\": \"0xYOUR_EIP712_SIGNATURE_HERE\"\n    },\n    \"content_type\": \"text/plain\",\n    \"visibility\": \"proof_only\",\n    \"tags\": [\"test\"],\n    \"fee_amount\": 0.0002,\n    \"fee_currency\": \"ETH\",\n    \"fee_tx_hash\": \"0xYOUR_TX_HASH_HERE\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{base_url}}/v1/records",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "v1",
                        "records"
                    ]
                },
                "description": "Creates a new Proof of Generation record.\n\n⚠️ IMPORTANT: This endpoint requires:\n1. A fee paid beforehand on Base Sepolia\n2. A valid EIP-712 signature of the pog_bundle\n\nFor the full flow, use the test-alpha.ts script from the repository."
            }
        },
        {
            "name": "📝 Create record + wait for anchoring",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"pog_bundle\": {\n        \"schema\": \"pog.v1\",\n        \"content_hash\": \"sha256:YOUR_SHA256_HASH_HERE\",\n        \"agent_wallet\": \"0xYOUR_WALLET_HERE\",\n        \"model_id\": \"gpt-4o\",\n        \"runtime_id\": \"postman-test\",\n        \"generation_process\": {\n            \"process_type\": \"direct\",\n            \"human_intervention_level\": 0,\n            \"pipeline_steps\": 1\n        },\n        \"timestamp\": \"2026-02-14T12:00:00.000Z\",\n        \"nonce\": \"your_unique_nonce_here\",\n        \"signature\": \"0xYOUR_EIP712_SIGNATURE_HERE\"\n    },\n    \"content_type\": \"text/plain\",\n    \"visibility\": \"proof_only\",\n    \"tags\": [\"test\"],\n    \"fee_amount\": 0.0002,\n    \"fee_currency\": \"ETH\",\n    \"fee_tx_hash\": \"0xYOUR_TX_HASH_HERE\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{base_url}}/v1/records?wait_for_anchor=true",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "v1",
                        "records"
                    ],
                    "query": [
                        {
                            "key": "wait_for_anchor",
                            "value": "true",
                            "description": "Waits up to 25s for anchoring to complete"
                        }
                    ]
                },
                "description": "Same as POST /records, but waits up to 25 seconds for the blockchain anchoring to complete before responding.\n\nIf anchoring does not complete in time, the record is still returned with state=pending_anchor and a Retry-After: 5 header."
            }
        },
        {
            "name": "🔍 Get record by ID",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/v1/records/{{record_id}}",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "v1",
                        "records",
                        "{{record_id}}"
                    ]
                },
                "description": "Retrieves the details of a record by its UUID.\n\nThe response includes:\n- state_info: structured state metadata (terminal, retryable, description)\n- anchor: with explorer_url and network_name\n- fee: with explorer_url and network_name"
            }
        },
        {
            "name": "✅ Verify by content_hash",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/v1/records/verify?content_hash={{content_hash}}",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "v1",
                        "records",
                        "verify"
                    ],
                    "query": [
                        {
                            "key": "content_hash",
                            "value": "{{content_hash}}",
                            "description": "SHA-256 hash of the content, format: sha256:64hex"
                        }
                    ]
                },
                "description": "Verifies whether a record exists for given content by its hash.\n\nReturns 200 with the record data if it exists,\nor 404 if no record was found with that hash."
            }
        },
        {
            "name": "📋 Export receipt (full)",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/v1/records/{{record_id}}/export",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "v1",
                        "records",
                        "{{record_id}}",
                        "export"
                    ]
                },
                "description": "Exports the complete verifiable receipt of a record.\n\nIncludes all data necessary for independent verification:\n- pog_bundle with eip712_domain\n- verification metadata\n- anchor with explorer_url\n- fee with explorer_url\n- state_info"
            }
        },
        {
            "name": "📋 Export receipt (compact)",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/v1/records/{{record_id}}/export?mode=compact",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "v1",
                        "records",
                        "{{record_id}}",
                        "export"
                    ],
                    "query": [
                        {
                            "key": "mode",
                            "value": "compact",
                            "description": "Returns only cryptographic verification fields"
                        }
                    ]
                },
                "description": "Reduced export with only the essential fields for cryptographic verification.\n\nOmits: fee, visibility, content_type, runtime_id, model_id.\nIdeal for AI agents (saves tokens) and for sharing proofs without operational data."
            }
        }
    ]
}