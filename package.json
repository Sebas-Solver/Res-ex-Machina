{
  "name": "res-ex-machina",
  "version": "1.0.0-alpha.2",
  "description": "Registro neutral y automatizado de hechos de generación por IA",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:strict": "eslint src/ --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint:strict && npm run test",
    "format": "prettier --write src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "worker:anchor": "tsx src/workers/anchor.worker.ts",
    "start:worker": "node dist/workers/anchor.worker.js",
    "alpha:happy": "tsx scripts/alpha/agent-a-happy-path.ts",
    "alpha:adversarial": "tsx scripts/alpha/agent-d-adversarial.ts",
    "alpha:all": "npm run alpha:happy && npm run alpha:adversarial",
    "smoke:live": "tsx scripts/smoke-test-live.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sebas-Solver/Res-ex-Machina.git"
  },
  "keywords": [],
  "author": "Sebas-Solver <sebas.solver@gmail.com>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Sebas-Solver/Res-ex-Machina/issues"
  },
  "homepage": "https://github.com/Sebas-Solver/Res-ex-Machina#readme",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@res-ex-machina/sdk": "^0.1.0",
    "@sentry/node": "^10.39.0",
    "@x402/core": "^2.11.0",
    "bullmq": "^5.67.3",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "ioredis": "^5.9.2",
    "postgres": "^3.4.8",
    "uuidv7": "^1.1.0",
    "viem": "^2.45.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  }
}
