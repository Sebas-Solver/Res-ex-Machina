{
  "name": "res-ex-machina",
  "version": "1.0.0",
  "description": "Registro neutral y automatizado de hechos de generación por IA",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "worker:anchor": "tsx src/workers/anchor.worker.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sebas-Solver/Res-ex-Machina.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Sebas-Solver/Res-ex-Machina/issues"
  },
  "homepage": "https://github.com/Sebas-Solver/Res-ex-Machina#readme",
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "bullmq": "^5.67.3",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "ioredis": "^5.9.2",
    "postgres": "^3.4.8",
    "redis": "^5.10.0",
    "uuidv7": "^1.1.0",
    "viem": "^2.45.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
